<!-- FAQ -->
<section class="sec rev" id="faq">
  <div class="sec-label">04 — faq</div>
  <div class="sec-title">Common<br><span class="dim">questions.</span></div>

  <div class="faq-list">
    <div class="faq-item">
      <div class="faq-q">Is CatWare detectable? <span class="faq-arr">›</span></div>
      <div class="faq-a">CatWare uses packet-level obfuscation and human-motion algorithms. It has never triggered Watchdog, NCP, Intave, or AAC in normal use.</div>
    </div>
