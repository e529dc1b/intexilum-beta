<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CatWare — Minecraft Client</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }

:root {
  --bg:   #04050a;
  --s1:   #080a12;
  --s2:   #0d1020;
  --s3:   #12162a;
  --a:    #1a1f3a;
  --r:    #7c1d1d;
  --r2:   #b91c1c;
  --r3:   #ef4444;
  --r4:   #f87171;
  --rg:   rgba(239,68,68,0.07);
  --rb:   rgba(239,68,68,0.18);
  --text: #eeeaf8;
  --t2:   #6e6a88;
  --t3:   #2e2c42;
  --mono: 'Space Mono', monospace;
  --disp: 'Bebas Neue', sans-serif;
  --body: 'DM Sans', sans-serif;
}

body { background: var(--bg); color: var(--text); font-family: var(--body); cursor: none; overflow-x: hidden; }
::selection { background: var(--r2); color: #fff; }
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--r2); }

/* CURSOR */
#cur { position: fixed; top: 0; left: 0; z-index: 9999; pointer-events: none; }
.cd { position: absolute; border-radius: 50%; transform: translate(-50%,-50%); }
.ci { width: 7px; height: 7px; background: #fff; mix-blend-mode: difference; transition: width .15s, height .15s; }
.co { width: 34px; height: 34px; border: 1px solid rgba(239,68,68,.55); transition: width .3s, height .3s, border-color .3s; }
body.hov .ci { width: 11px; height: 11px; }
body.hov .co { width: 54px; height: 54px; border-color: var(--r3); }

/* CANVAS + OVERLAYS */
#cv { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
.noise {
  position: fixed; inset: 0; z-index: 1; pointer-events: none; opacity: .28;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.05'/%3E%3C/svg%3E");
}
.vig { position: fixed; inset: 0; z-index: 2; pointer-events: none; background: radial-gradient(ellipse at 50% 40%, transparent 35%, rgba(4,5,10,.85) 100%); }

.page { position: relative; z-index: 10; }

/* NAV */
nav {
  position: fixed; inset: 0 0 auto; z-index: 200;
  height: 56px; padding: 0 3rem;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(4,5,10,.75); backdrop-filter: blur(18px);
  border-bottom: 1px solid rgba(255,255,255,.04);
}
.logo { font-family: var(--mono); font-size: 15px; color: var(--text); text-decoration: none; display: flex; align-items: center; gap: 10px; }
.logo-sq { width: 9px; height: 9px; background: var(--r3); display: inline-block; animation: sq 2.2s ease-in-out infinite; }
@keyframes sq { 0%,100%{opacity:1;transform:rotate(0)} 50%{opacity:.4;transform:rotate(45deg)} }
.logo em { font-style: normal; color: var(--r4); }
.nav-r { display: flex; align-items: center; gap: 2.2rem; }
.nav-r a { font-family: var(--mono); font-size: 11px; color: var(--t2); text-decoration: none; letter-spacing: .12em; text-transform: uppercase; transition: color .25s; }
.nav-r a:hover { color: var(--r3); }
.nav-dl { background: var(--r2); color: #fff; font-family: var(--mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; padding: 8px 20px; border-radius: 3px; text-decoration: none; transition: background .2s; }
.nav-dl:hover { background: var(--r3); }

/* HERO */
.hero {
  min-height: 100vh; padding: 9rem 3rem 5rem;
  max-width: 1100px; margin: 0 auto;
  display: flex; flex-direction: column; justify-content: center;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 10px;
  border: 1px solid var(--r); background: var(--rg);
  color: var(--r4); font-family: var(--mono); font-size: 11px;
  letter-spacing: .12em; text-transform: uppercase;
  padding: 6px 16px; border-radius: 2px;
  margin-bottom: 2.5rem; width: fit-content;
  opacity: 0; animation: fup .8s .2s forwards;
}
.pulse { width: 7px; height: 7px; background: var(--r3); border-radius: 50%; animation: pl 1.6s infinite; }
@keyframes pl { 0%,100%{opacity:1} 50%{opacity:.2} }

.hero h1 {
  font-family: var(--disp);
  font-size: clamp(4.5rem, 13vw, 10rem);
  line-height: .92; letter-spacing: .02em;
  opacity: 0; animation: fup .9s .4s forwards;
}
.hero h1 .r { color: var(--r3); }
.hero h1 .s { -webkit-text-stroke: 1.5px var(--r); color: transparent; }

.hero-sub {
  font-size: 16px; color: var(--t2); max-width: 480px;
  line-height: 1.85; margin-top: 2.2rem;
  opacity: 0; animation: fup .9s .6s forwards;
}
.hero-sub strong { color: var(--text); font-weight: 500; }

.hero-actions {
  display: flex; gap: 12px; flex-wrap: wrap; margin-top: 2.5rem;
  opacity: 0; animation: fup .9s .8s forwards;
}

.btn { font-family: var(--mono); font-size: 12px; letter-spacing: .1em; text-transform: uppercase; padding: 12px 28px; border-radius: 3px; text-decoration: none; transition: all .25s; display: inline-block; cursor: none; }
.btn-red { background: var(--r2); color: #fff; border: 1px solid var(--r3); }
.btn-red:hover { background: var(--r3); transform: translateY(-1px); }
.btn-ghost { background: transparent; color: var(--t2); border: 1px solid var(--t3); }
.btn-ghost:hover { border-color: var(--r); color: var(--text); }

.hero-nums {
  display: flex; gap: 3.5rem; flex-wrap: wrap;
  margin-top: 4rem; padding-top: 3rem;
  border-top: 1px solid rgba(255,255,255,.05);
  opacity: 0; animation: fup .9s 1s forwards;
}
.hnum-v { font-family: var(--disp); font-size: 3rem; color: var(--r4); line-height: 1; }
.hnum-l { font-family: var(--mono); font-size: 10px; color: var(--t3); letter-spacing: .12em; text-transform: uppercase; margin-top: 6px; }

@keyframes fup { from{opacity:0;transform:translateY(22px)} to{opacity:1;transform:none} }

/* SECTIONS */
.sec { max-width: 1100px; margin: 0 auto; padding: 7rem 3rem; }

.sec-label {
  font-family: var(--mono); font-size: 10px;
  color: var(--r2); letter-spacing: .22em; text-transform: uppercase;
  margin-bottom: .9rem; display: flex; align-items: center; gap: 12px;
}
.sec-label::before { content:''; display:block; width:28px; height:1px; background:var(--r2); }
.sec-title { font-family: var(--disp); font-size: clamp(2.8rem,6vw,5rem); line-height: .95; letter-spacing: .02em; }
.sec-title .dim { color: var(--t3); }
.sec-body { font-size: 15px; color: var(--t2); line-height: 1.85; max-width: 480px; margin-top: 1rem; }

/* FEATURES GRID */
.feat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px,1fr)); gap: 1px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.04); border-radius: 6px; overflow: hidden; margin-top: 3rem; }
.feat-card { background: var(--s1); padding: 1.8rem; position: relative; overflow: hidden; transition: background .3s; }
.feat-card::before { content:''; position:absolute; left:0; top:0; width:3px; height:100%; background: transparent; transition: background .3s; }
.feat-card:hover { background: var(--s2); }
.feat-card:hover::before { background: var(--r3); }
.feat-icon { font-size: 26px; margin-bottom: 1rem; display:flex; align-items:center; justify-content:center; width:46px; height:46px; background:var(--rg); border:1px solid var(--r); border-radius:5px; }
.feat-name { font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 6px; }
.feat-desc { font-size: 13px; color: var(--t2); line-height: 1.7; }
.feat-pill { display:inline-block; margin-top:12px; font-family:var(--mono); font-size:10px; letter-spacing:.08em; text-transform:uppercase; padding:3px 10px; border-radius:2px; background:var(--rg); color:var(--r4); border:1px solid var(--r); }

/* MODULES */
.mod-list { display:flex; flex-direction:column; gap:1px; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.04); border-radius:6px; overflow:hidden; margin-top:3rem; }
.mod-row { display:grid; grid-template-columns:52px 1fr auto; align-items:center; gap:1.5rem; padding:1.2rem 1.4rem; background:var(--s1); border-left:3px solid transparent; transition:all .3s; cursor:none; }
.mod-row:hover { background:var(--s2); border-left-color:var(--r3); }
.mod-num { font-family:var(--mono); font-size:10px; color:var(--t3); text-align:center; }
.mod-ico { font-size:20px; }
.mod-info { display:flex; flex-direction:column; gap:3px; }
.mod-name { font-family:var(--mono); font-size:13px; font-weight:700; color:var(--text); }
.mod-desc { font-size:12px; color:var(--t2); }
.mod-right { display:flex; align-items:center; gap:10px; flex-shrink:0; }
.badge { font-family:var(--mono); font-size:10px; padding:3px 10px; border-radius:20px; letter-spacing:.06em; white-space:nowrap; }
.bg { background:rgba(34,197,94,.1); color:#4ade80; border:1px solid rgba(34,197,94,.22); }
.by { background:rgba(234,179,8,.1); color:#fbbf24; border:1px solid rgba(234,179,8,.22); }
.br { background:rgba(239,68,68,.1); color:var(--r4); border:1px solid rgba(239,68,68,.22); }
.bb { background:rgba(96,165,250,.1); color:#93c5fd; border:1px solid rgba(96,165,250,.22); }
.tog { width:36px; height:20px; border-radius:10px; background:var(--r2); position:relative; cursor:none; flex-shrink:0; transition:background .2s; }
.tog::after { content:''; position:absolute; top:3px; right:3px; width:14px; height:14px; border-radius:50%; background:#fff; transition:right .2s; }
.tog.off { background:var(--t3); }
.tog.off::after { right:auto; left:3px; }

/* PRICING */
.price-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:14px; margin-top:3rem; }
.pcard { background:var(--s1); border:1px solid rgba(255,255,255,.06); border-radius:8px; padding:2rem; position:relative; transition:border-color .3s; }
.pcard:hover { border-color: rgba(239,68,68,.3); }
.pcard.feat { border-color:var(--r2); background:var(--s2); }
.feat-lbl { position:absolute; top:-13px; left:50%; transform:translateX(-50%); background:var(--r2); color:#fff; font-family:var(--mono); font-size:10px; letter-spacing:.1em; text-transform:uppercase; padding:4px 16px; border-radius:20px; white-space:nowrap; }
.p-tier { font-family:var(--mono); font-size:10px; color:var(--t3); letter-spacing:.14em; text-transform:uppercase; margin-bottom:.75rem; }
.p-val { font-family:var(--disp); font-size:3.2rem; color:var(--text); line-height:1; }
.p-val span { font-family:var(--body); font-size:.95rem; color:var(--t2); font-weight:300; }
.p-note { font-size:13px; color:var(--t2); margin:.75rem 0 1.5rem; }
.p-list { list-style:none; display:flex; flex-direction:column; gap:9px; margin-bottom:1.75rem; }
.p-list li { font-size:13px; color:var(--t2); display:flex; align-items:center; gap:8px; }
.p-list li::before { content:'✓'; color:var(--r3); font-weight:700; flex-shrink:0; }
.p-list li.no { color:var(--t3); }
.p-list li.no::before { content:'✗'; color:var(--t3); }
.p-btn { display:block; width:100%; padding:12px; border-radius:5px; font-family:var(--mono); font-size:12px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; text-align:center; text-decoration:none; cursor:none; transition:all .25s; }
.p-btn-r { background:var(--r2); color:#fff; border:none; }
.p-btn-r:hover { background:var(--r3); }
.p-btn-o { background:transparent; color:var(--t2); border:1px solid var(--t3); }
.p-btn-o:hover { border-color:var(--r); color:var(--text); }

/* FAQ */
.faq-list { display:flex; flex-direction:column; gap:1px; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.04); border-radius:6px; overflow:hidden; margin-top:3rem; }
.faq-item { background:var(--s1); padding:1.1rem 1.4rem; cursor:none; transition:background .25s; }
.faq-item:hover { background:var(--s2); }
.faq-q { font-size:14px; font-weight:500; color:var(--text); display:flex; justify-content:space-between; align-items:center; }
.faq-arr { color:var(--r3); font-size:18px; transition:transform .25s; flex-shrink:0; margin-left:1rem; }
.faq-a { font-size:13px; color:var(--t2); margin-top:.75rem; line-height:1.75; display:none; }
.faq-item.open .faq-a { display:block; }
.faq-item.open .faq-arr { transform:rotate(90deg); }

/* FOOTER */
footer { border-top:1px solid rgba(255,255,255,.04); padding:2rem 3rem; max-width:1100px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem; }
.fl { font-family:var(--mono); font-size:11px; color:var(--t3); }
.fl em { font-style:normal; color:var(--r4); }

hr.div { border:none; border-top:1px solid rgba(255,255,255,.04); max-width:1100px; margin:0 auto; }

/* REVEAL */
.rev { opacity:0; transform:translateY(28px); transition:opacity .85s ease, transform .85s ease; }
.rev.on { opacity:1; transform:none; }

@media(max-width:640px){
  nav{padding:0 1.25rem;}
  .nav-r a{display:none;}
  .hero,.sec{padding-left:1.25rem;padding-right:1.25rem;}
  .hero{padding-top:7rem;}
  .mod-row{grid-template-columns:1fr auto;}
  .mod-num{display:none;}
}
</style>
</head>
<body>

<!-- CURSOR -->
<div id="cur">
  <div class="cd co" id="co"></div>
  <div class="cd ci" id="ci"></div>
</div>

<canvas id="cv"></canvas>
<div class="noise"></div>
<div class="vig"></div>

<div class="page">

<!-- NAV -->
<nav>
  <a href="#" class="logo">
    <span class="logo-sq"></span>
    Cat<em>Ware</em>
  </a>
  <div class="nav-r">
    <a href="#features">Features</a>
    <a href="#modules">Modules</a>
    <a href="#pricing">Pricing</a>
    <a href="#faq">FAQ</a>
    <a href="#" class="nav-dl">Download</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-badge"><div class="pulse"></div>UNDETECTED · v2.4.1 · MC 1.21.4</div>
  <h1>CAT<span class="r">W</span><span class="s">ARE</span><br><span class="s">CLI</span><span class="r">ENT</span></h1>
  <p class="hero-sub">
    The most advanced Minecraft utility mod ever built.<br>
    <strong>83 modules. Zero detections. One client.</strong>
  </p>
  <div class="hero-actions">
    <a href="#pricing" class="btn btn-red">Get Access</a>
    <a href="#modules" class="btn btn-ghost">View Modules</a>
  </div>
  <div class="hero-nums">
    <div><div class="hnum-v">48k</div><div class="hnum-l">active users</div></div>
    <div><div class="hnum-v">83</div><div class="hnum-l">modules</div></div>
    <div><div class="hnum-v">0</div><div class="hnum-l">detections</div></div>
    <div><div class="hnum-v">1.8→1.21</div><div class="hnum-l">versions</div></div>
  </div>
</section>

<hr class="div">

<!-- FEATURES -->
<section class="sec rev" id="features">
  <div class="sec-label">01 — why catware</div>
  <div class="sec-title">Built<br><span class="dim">different.</span></div>
  <p class="sec-body">Every feature engineered for performance, stealth, and usability. No bloat, no backdoors — just a clean, fast client.</p>

  <div class="feat-grid">
    <div class="feat-card">
      <div class="feat-icon">🛡️</div>
      <div class="feat-name">Anti-Cheat Bypass</div>
      <div class="feat-desc">Bypasses Watchdog, NCP, Intave and AAC with advanced packet obfuscation and human-motion simulation.</div>
      <span class="feat-pill">stealth</span>
    </div>
    <div class="feat-card">
      <div class="feat-icon">⚡</div>
      <div class="feat-name">Zero Overhead</div>
      <div class="feat-desc">Async thread architecture. CatWare adds virtually no FPS impact — tested at sub-0.3ms per tick.</div>
      <span class="feat-pill">performance</span>
    </div>
    <div class="feat-card">
      <div class="feat-icon">🎨</div>
      <div class="feat-name">Click GUI + HUD</div>
      <div class="feat-desc">Sleek in-game interface. Drag-and-drop HUD editor. Resize, recolor, and configure everything live.</div>
      <span class="feat-pill">ui/ux</span>
    </div>
    <div class="feat-card">
      <div class="feat-icon">🔧</div>
      <div class="feat-name">Deep Config</div>
      <div class="feat-desc">Every module exposes sliders, toggles, keybinds. Save per-server config profiles and switch instantly.</div>
      <span class="feat-pill">customization</span>
    </div>
    <div class="feat-card">
      <div class="feat-icon">🔄</div>
      <div class="feat-name">Silent Auto-Update</div>
      <div class="feat-desc">New bypasses and modules ship automatically in the background. Always on the latest patch, always safe.</div>
      <span class="feat-pill">updates</span>
    </div>
    <div class="feat-card">
      <div class="feat-icon">🌐</div>
      <div class="feat-name">1.8 → 1.21.4</div>
      <div class="feat-desc">Full multi-version support from the launcher. Switch Minecraft versions without reinstalling.</div>
      <span class="feat-pill">compatibility</span>
    </div>
  </div>
</section>

<hr class="div">

<!-- MODULES -->
<section class="sec rev" id="modules">
  <div class="sec-label">02 — modules</div>
  <div class="sec-title">83 modules.<br><span class="dim">All categories.</span></div>
  <p class="sec-body">Combat, movement, visual, world — everything you need, all configurable to the last detail.</p>

  <div class="mod-list">
    <div class="mod-row">
      <div class="mod-num">01</div>
      <div style="display:flex;align-items:center;gap:12px;">
        <div class="mod-ico">⚔️</div>
        <div class="mod-info">
          <div class="mod-name">KillAura</div>
          <div class="mod-desc">Auto-attacks players and mobs in configurable range with rotation modes</div>
        </div>
      </div>
      <div class="mod-right"><span class="badge by">COMBAT</span><div class="tog"></div></div>
    </div>
    <div class="mod-row">
      <div class="mod-num">02</div>
      <div style="display:flex;align-items:center;gap:12px;">
        <div class="mod-ico">💎</div>
        <div class="mod-info">
          <div class="mod-name">AutoCrystal</div>
          <div class="mod-desc">Places and explodes end crystals automatically for maximum damage output</div>
        </div>
      </div>
      <div class="mod-right"><span class="badge by">COMBAT</span><div class="tog off"></div></div>
    </div>
    <div class="mod-row">
      <div class="mod-num">03</div>
      <div style="display:flex;align-items:center;gap:12px;">
        <div class="mod-ico">👁️</div>
        <div class="mod-info">
          <div class="mod-name">ESP</div>
          <div class="mod-desc">Renders player outlines and boxes through walls with distance and health display</div>
        </div>
      </div>
      <div class="mod-right"><span class="badge bb">VISUAL</span><div class="tog"></div></div>
    </div>
    <div class="mod-row">
      <div class="mod-num">04</div>
      <div style="display:flex;align-items:center;gap:12px;">
        <div class="mod-ico">🏗️</div>
        <div class="mod-info">
          <div class="mod-name">Scaffold</div>
          <div class="mod-desc">Automatically bridges blocks beneath you while moving at full sprint speed</div>
        </div>
      </div>
      <div class="mod-right"><span class="badge bg">MOVEMENT</span><div class="tog"></div></div>
    </div>
    <div class="mod-row">
      <div class="mod-num">05</div>
      <div style="display:flex;align-items:center;gap:12px;">
        <div class="mod-ico">🦅</div>
        <div class="mod-info">
          <div class="mod-name">Flight</div>
          <div class="mod-desc">Bypass-mode flight in survival with configurable speed and anti-kick timings</div>
        </div>
      </div>
      <div class="mod-right"><span class="badge bg">MOVEMENT</span><div class="tog off"></div></div>
    </div>
    <div class="mod-row">
      <div class="mod-num">06</div>
      <div style="display:flex;align-items:center;gap:12px;">
        <div class="mod-ico">📍</div>
        <div class="mod-info">
          <div class="mod-name">Tracers</div>
          <div class="mod-desc">Draws colored lines from screen center to all nearby entities and players</div>
        </div>
      </div>
      <div class="mod-right"><span class="badge bb">VISUAL</span><div class="tog"></div></div>
    </div>
    <div class="mod-row">
      <div class="mod-num">07</div>
      <div style="display:flex;align-items:center;gap:12px;">
        <div class="mod-ico">⛏️</div>
        <div class="mod-info">
          <div class="mod-name">Nuker</div>
          <div class="mod-desc">Breaks blocks in radius at extreme speed — tree, sphere, and flat modes</div>
        </div>
      </div>
      <div class="mod-right"><span class="badge br">WORLD</span><div class="tog off"></div></div>
    </div>
    <div class="mod-row">
      <div class="mod-num">08</div>
      <div style="display:flex;align-items:center;gap:12px;">
        <div class="mod-ico">💨</div>
        <div class="mod-info">
          <div class="mod-name">Speed</div>
          <div class="mod-desc">Multiple speed modes — Strafe, Vanilla, Bypass — each tuned for different anti-cheats</div>
        </div>
      </div>
      <div class="mod-right"><span class="badge bg">MOVEMENT</span><div class="tog off"></div></div>
